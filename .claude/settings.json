{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "mcpServers": {
    "context-mode": {
      "command": "uv",
      "args": ["run", "--project", ".", "python3", "context_mode/server.py"]
    },
    "gtmetrix": {
      "command": "uv",
      "args": ["run", "--project", ".", "python3", "main.py"]
    },
    "semrush": {
      "command": "npx",
      "args": ["-y", "semrush-mcp"],
      "env": { "SEMRUSH_API_KEY": "${SEMRUSH_API_KEY}" }
    },
    "firecrawl": {
      "command": "npx",
      "args": ["-y", "firecrawl-mcp"],
      "env": { "FIRECRAWL_API_KEY": "${FIRECRAWL_API_KEY}" }
    },
    "airtable": {
      "command": "npx",
      "args": ["-y", "@domdomegg/airtable-mcp-server"],
      "env": { "AIRTABLE_API_KEY": "${AIRTABLE_API_KEY}" }
    },
    "gsc": {
      "command": "npx",
      "args": ["-y", "mcp-gsc"],
      "env": {
        "GSC_CREDENTIALS_PATH": "/tmp/creds/gsc.json",
        "GSC_SITE_URL": "${GSC_SITE_URL}"
      }
    },
    "google-workspace": {
      "command": "uvx",
      "args": ["google-workspace-mcp"],
      "env": {
        "GOOGLE_CREDENTIALS_PATH": "/tmp/creds/gws.json",
        "GOOGLE_TOOL_TIER": "core"
      }
    },
    "vault": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "vault"]
    }
  },

  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "GITHUB_REPO": "simonmannheimer-tgg/Claude",
    "GSC_SITE_URL": "https://www.thegoodguys.com.au/"
  },

  "permissions": {
    "allow": [
      "Read", "Glob", "Grep",
      "Write(seo/outputs/**)", "Write(seo/briefs/**)",
      "Write(.claude/skills/**)", "Write(docs/**)", "Write(scripts/**)", "Write(tools/**)",
      "Bash(uv:*)", "Bash(python3:*)", "Bash(python:*)",
      "Bash(node:*)", "Bash(npx:*)",
      "Bash(git status:*)", "Bash(git add:*)", "Bash(git commit:*)",
      "Bash(git push:*)", "Bash(git fetch:*)", "Bash(git pull:*)",
      "Bash(git log:*)", "Bash(git diff:*)", "Bash(git branch:*)",
      "Bash(wc:*)", "Bash(head:*)", "Bash(tail:*)",
      "Bash(grep:*)", "Bash(cat:*)", "Bash(ls:*)", "Bash(find:*)",
      "Bash(sort:*)", "Bash(uniq:*)", "Bash(awk:*)", "Bash(sed:*)",
      "mcp__context-mode__*", "mcp__semrush__*",
      "mcp__firecrawl__*", "mcp__airtable__*",
      "mcp__gsc__*", "mcp__google-workspace__*", "mcp__vault__*"
    ],
    "deny": [
      "Read(.env)", "Read(.env.*)", "Read(**/.env)",
      "Bash(curl:*)", "Bash(wget:*)",
      "Bash(rm -rf:*)", "Bash(git push --force:*)", "Bash(git reset --hard:*)",
      "Write(.env)", "Write(.env.*)"
    ],
    "defaultMode": "default"
  },

  "hooks": {
    "SessionStart": [
      { "hooks": [{ "type": "command", "command": "bash .claude/hooks/session_start.sh" }] }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": "python3 .claude/hooks/block_dangerous.py" }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [{ "type": "command", "command": "python3 .claude/hooks/log_writes.py" }]
      }
    ],
    "Stop": [
      { "hooks": [{ "type": "command", "command": "python3 .claude/hooks/session_log.py" }] }
    ]
  }
}
