{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "mcpServers": {
    "context-mode": {
      "command": "uv",
      "args": [
        "run",
        "--project",
        "/home/user/Claude",
        "python3",
        "/home/user/Claude/context_mode/server.py"
      ]
    },
    "gtmetrix": {
      "command": "uv",
      "args": [
        "run",
        "--project",
        "/home/user/Claude",
        "python3",
        "/home/user/Claude/main.py"
      ]
    },
    "semrush": {
      "command": "npx",
      "args": ["-y", "semrush-mcp"],
      "env": {
        "SEMRUSH_API_KEY": "${SEMRUSH_API_KEY}"
      }
    }
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "PAT_TOKEN_GH": "${PAT_TOKEN_GH}",
    "GITHUB_REPO": "simonmannheimer-tgg/Claude"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/user/Claude/scripts/loop-daemon.sh >> /tmp/claude-loop.log 2>&1",
            "async": true,
            "statusMessage": "Starting GitHub discussion loop..."
          }
        ]
      }
    ]
  }
}
