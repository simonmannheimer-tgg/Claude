{
  "mcpServers": {
    "context-mode": {
      "command": "uv",
      "args": ["run", "python3", "context_mode/server.py"]
    },
    "semrush": {
      "command": "npx",
      "args": ["-y", "semrush-mcp"],
      "env": { "SEMRUSH_API_KEY": "$SEMRUSH_API_KEY" }
    },
    "firecrawl": {
      "command": "npx",
      "args": ["-y", "firecrawl-mcp"],
      "env": { "FIRECRAWL_API_KEY": "$FIRECRAWL_API_KEY" }
    }
  }
}
