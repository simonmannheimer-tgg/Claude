# Copy this file to .env and fill in your keys.
# The .env file is in .gitignore — never commit it.

# GTMetrix
GTMETRIX_API_KEY=your_api_key_here
GTMETRIX_DEFAULT_LOCATION=4
GTMETRIX_CREDIT_FLOOR=10
GTMETRIX_POLL_INTERVAL=5
GTMETRIX_MAX_WAIT=300
GTMETRIX_BULK_DELAY=2.0
GTMETRIX_OUTPUT_DIR=./reports

# Semrush
SEMRUSH_API_KEY=your_semrush_key_here

# Firecrawl (firecrawl.dev — free tier available)
FIRECRAWL_API_KEY=your_firecrawl_key_here

# Airtable (base: appS4NfrOth5cVo7P)
AIRTABLE_API_KEY=your_airtable_key_here

# GitHub PAT (for scripts/github-poll.sh and issue posting)
PAT_TOKEN_GH=your_github_pat_here

# Optional — Google Search Console (requires local credentials file, set in settings.local.json)
# GSC_CREDENTIALS_PATH=/absolute/path/to/gsc-credentials.json
# GSC_SITE_URL=https://www.thegoodguys.com.au/

# Optional — Linear
# LINEAR_API_KEY=your_linear_key_here
