# Copy this file to .env and fill in your GTMetrix API key.
# The .env file is in .gitignore — never commit it.

# Required
GTMETRIX_API_KEY=your_api_key_here

# Test defaults
# Location 4 = San Antonio (GTMetrix free tier default)
# Use list_locations tool to find the best location for AU testing
GTMETRIX_DEFAULT_LOCATION=4

# Safety — abort any run if remaining credits would drop below this number
GTMETRIX_CREDIT_FLOOR=10

# Polling (seconds)
GTMETRIX_POLL_INTERVAL=5
GTMETRIX_MAX_WAIT=300

# Bulk runs — pause between tests to avoid hammering the API
GTMETRIX_BULK_DELAY=2.0

# Output directory for CSV and JSON reports
GTMETRIX_OUTPUT_DIR=./reports
